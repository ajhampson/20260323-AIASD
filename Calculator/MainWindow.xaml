<Window x:Class="CalculatorNamespace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator"
        Width="360"
        Height="540"
        Background="#FFECECEC"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="CalculatorButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="6" />
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFF8F8F8" />
            <Setter Property="BorderBrush" Value="#FFD0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="OperatorButtonStyle" TargetType="Button" BasedOn="{StaticResource CalculatorButtonStyle}">
            <Setter Property="Background" Value="#FFE8E8E8" />
        </Style>

        <Style x:Key="EqualsButtonStyle" TargetType="Button" BasedOn="{StaticResource CalculatorButtonStyle}">
            <Setter Property="Background" Value="#FF0B57D0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF0B57D0" />
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Padding="14"
            Background="White"
            BorderBrush="#FFD8D8D8"
            BorderThickness="1"
            CornerRadius="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Calculator"
                       FontSize="20"
                       FontWeight="SemiBold" />

            <Border Grid.Row="1"
                    Margin="0,12,0,12"
                    Padding="12"
                    Background="#FF1F1F1F"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ExpressionTextBlock"
                               HorizontalAlignment="Right"
                               Foreground="#FFB9B9B9"
                               FontSize="16" />

                    <TextBlock x:Name="ResultTextBlock"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Right"
                               Foreground="#FFB9B9B9"
                               FontSize="14" />

                    <TextBox x:Name="DisplayTextBox"
                             Grid.Row="2"
                             Margin="0,8,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="34"
                             FontWeight="SemiBold"
                             HorizontalContentAlignment="Right"
                             IsReadOnly="True"
                             Text="0" />
                </Grid>
            </Border>

            <TextBlock x:Name="MessageTextBlock"
                       Grid.Row="2"
                       Margin="0,0,0,6"
                       Foreground="Firebrick"
                       TextWrapping="Wrap" />

            <UniformGrid Grid.Row="3"
                         Rows="5"
                         Columns="4">
                <Button Style="{StaticResource OperatorButtonStyle}" Click="OperatorButton_Click" Tag="%" Content="%" />
                <Button Style="{StaticResource OperatorButtonStyle}" Click="ClearButton_Click" Content="C" />
                <Button Style="{StaticResource OperatorButtonStyle}" Click="ResetButton_Click" Content="CE" />
                <Button Style="{StaticResource OperatorButtonStyle}" Click="OperatorButton_Click" Tag="/" Content="÷" />

                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="7" Content="7" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="8" Content="8" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="9" Content="9" />
                <Button Style="{StaticResource OperatorButtonStyle}" Click="OperatorButton_Click" Tag="*" Content="×" />

                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="4" Content="4" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="5" Content="5" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="6" Content="6" />
                <Button Style="{StaticResource OperatorButtonStyle}" Click="OperatorButton_Click" Tag="-" Content="-" />

                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="1" Content="1" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="2" Content="2" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="3" Content="3" />
                <Button Style="{StaticResource OperatorButtonStyle}" Click="OperatorButton_Click" Tag="+" Content="+" />

                <Button Style="{StaticResource CalculatorButtonStyle}" Click="ToggleSignButton_Click" Content="+/-" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DigitButton_Click" Tag="0" Content="0" />
                <Button Style="{StaticResource CalculatorButtonStyle}" Click="DecimalButton_Click" Content="." />
                <Button Style="{StaticResource EqualsButtonStyle}" Click="EqualsButton_Click" Content="=" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>